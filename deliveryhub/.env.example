# ─────────────────────────────────────────────
# DATABASE (Neon.tech — copie a connection string do painel)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/deliveryhub?sslmode=require"

# ─────────────────────────────────────────────
# AUTH — gere valores seguros em: https://generate-secret.vercel.app/32
# ─────────────────────────────────────────────
JWT_SECRET="gere-um-valor-aleatorio-de-32-chars-aqui"
JWT_REFRESH_SECRET="gere-outro-valor-aleatorio-de-32-chars-aqui"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─────────────────────────────────────────────
# APP — após criar o projeto no Vercel, copie a URL gerada
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://seu-projeto.vercel.app"
NODE_ENV="production"

# ─────────────────────────────────────────────
# iFood (futuro — deixe vazio por enquanto)
# ─────────────────────────────────────────────
IFOOD_CLIENT_ID=""
IFOOD_CLIENT_SECRET=""
IFOOD_WEBHOOK_SECRET=""

# ─────────────────────────────────────────────
# Email (futuro — deixe vazio por enquanto)
# ─────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
